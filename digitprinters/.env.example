# ========================================
# Deriv Configuration
# ========================================

# Deriv OAuth App ID (from https://developers.deriv.com/)
VITE_DERIV_APP_ID=your_deriv_app_id

# OAuth callback redirect URI (must match exactly what's registered on Deriv)
# Production: https://yourdomain.com/auth/callback
# Local: http://localhost:5173/auth/callback
VITE_DERIV_OAUTH_REDIRECT_URI=https://yourdomain.com/auth/callback

# ========================================
# Canonical domain redirect (optional)
# ========================================

# If set, non-www requests to NON_CANONICAL_HOST are redirected to CANONICAL_HOST
VITE_CANONICAL_HOST=www.yourdomain.com
VITE_NON_CANONICAL_HOST=yourdomain.com

# ========================================
# Server-Side OAuth Configuration (hosting provider env vars)
# ========================================

# Deriv OAuth Client Secret (Backend only - never commit to repo)
# Used by /api/oauth-token endpoint to exchange code for access token
DERIV_OAUTH_CLIENT_SECRET=your_deriv_oauth_client_secret

# OAuth redirect URI for server-side token exchange (must match VITE_DERIV_OAUTH_REDIRECT_URI)
DERIV_OAUTH_REDIRECT_URI=https://yourdomain.com/auth/callback

# ========================================
# API Configuration
# ========================================

VITE_API_BASE_URL=https://your-api-domain.example

# ========================================
# Environment Settings
# ========================================

VITE_ENV=development
